<aura:component description="Enterprise Agnostic Dynamic Workspace Canvas Controller">
    <aura:attribute name="currentViewName" type="String" default="Dashboard UI" />
    <aura:attribute name="activeViewMetadata" type="String" default="{}" />
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <div class="slds-box slds-theme_default slds-var-m-around_medium">
        <div class="slds-page-header slds-var-m-bottom_medium">
            <div class="slds-page-header__row">
                <div class="slds-page-header__col-title">
                    <div class="slds-media">
                        <div class="slds-media__body">
                            <span class="slds-text-title_caps">Aura Micro-Frontend Canvas Engine</span>
                            <h1 class="slds-page-header__title slds-truncate">{!v.currentViewName}</h1>
                        </div>
                    </div>
                </div>
                <div class="slds-page-header__col-actions">
                    <lightning:buttonGroup>
                        <lightning:button label="Load Account Grid Module" onclick="{!c.handleLoadAccountGrid}" variant="neutral" />
                        <lightning:button label="Load System Diagnostics" onclick="{!c.handleLoadDiagnostics}" variant="neutral" />
                    </lightning:buttonGroup>
                </div>
            </div>
        </div>

        <div class="workspace-viewport slds-is-relative">
            {!v.body}
        </div>
    </div>
</aura:component>
